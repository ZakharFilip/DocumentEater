<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:DocumentEater.ViewModels;assembly=DocumentEater"
             xmlns:dgrid="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
             x:Class="DocumentEater.Pages.ResultTablePage"
             mc:Ignorable="d">
    <Grid RowDefinitions="Auto,Auto,*" Margin="16">
        <TextBlock Text="Конструктор итоговой таблицы"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,8"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
            <Button Content="Выгрузка в Excel"
                    Command="{Binding ExportToExcelCommand}"/>
            <TextBlock Text="(логика экспорта будет реализована в модуле 4)"
                       VerticalAlignment="Center"
                       Opacity="0.7"
                       FontSize="11"/>
        </StackPanel>

        <!-- Таблица результатов на базе DataGrid -->
        <dgrid:DataGrid Grid.Row="2"
                        ItemsSource="{Binding Rows}"
                        AutoGenerateColumns="False"
                        HeadersVisibility="All">
            <dgrid:DataGrid.Columns>
                <dgrid:DataGridTextColumn Header="№"
                                          Binding="{Binding Col1}" />
                <dgrid:DataGridTextColumn Header="Документ"
                                          Binding="{Binding Col2}" />
                <dgrid:DataGridTextColumn Header="Тип"
                                          Binding="{Binding Col3}" />
                <dgrid:DataGridTextColumn Header="Дата"
                                          Binding="{Binding Col4}" />
                <dgrid:DataGridTextColumn Header="Комментарий"
                                          Binding="{Binding Col5}" />
            </dgrid:DataGrid.Columns>
        </dgrid:DataGrid>
    </Grid>
</UserControl>
