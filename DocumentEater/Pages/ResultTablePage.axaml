<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DocumentEater.ViewModels;assembly=DocumentEater"
             x:Class="DocumentEater.Pages.ResultTablePage"
             x:DataType="vm:ResultTablePageViewModel">
    <Grid RowDefinitions="Auto,*" Margin="16">
        <TextBlock Text="Результаты" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>
        <DataGrid x:Name="ResultGrid"
                  Grid.Row="1"
                  ItemsSource="{Binding Rows}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="True"
                  GridLinesVisibility="All"
                  MinHeight="240"
                  MinWidth="400">
            <DataGrid.Styles>
                <Style Selector="DataGridCell">
                    <Setter Property="MinHeight" Value="28"/>
                    <Setter Property="VerticalContentAlignment" Value="Top"/>
                </Style>
            </DataGrid.Styles>
        </DataGrid>
    </Grid>
</UserControl>
